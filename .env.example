# ─────────────────────────────────────────
# Deploy Club AI Pipeline — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────

# Anthropic API (generate_ad.js + generate_copy.js)
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Tavily AI (Research Agent)
# Get your key at: https://tavily.com
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxx

# Upstash Redis (BullMQ Job Queue)
# Get from: https://console.upstash.com → Redis
#
# REDIS_URL  → "Redis" tab → "Connect" → copy the rediss:// URL
# REST vars  → "REST API" tab (used by other tools, not BullMQ)
UPSTASH_REDIS_URL=rediss://default:PASSWORD@HOSTNAME.upstash.io:6379
UPSTASH_REDIS_REST_URL=https://HOSTNAME.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# Supabase (Media Hosting)
# Get from: https://supabase.com → Project Settings → API
# Use the SERVICE KEY (not anon key) — needed for storage uploads
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# Instagram Graph API (Distribution Agent)
# Get from: https://developers.facebook.com → Your App → Instagram Basic Display
INSTAGRAM_ACCOUNT_ID=17841xxxxxxxxxx
INSTAGRAM_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxx

# YouTube Data API (Distribution Agent)
# Get from: https://console.cloud.google.com → APIs → YouTube Data API v3
YOUTUBE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxx
YOUTUBE_REDIRECT_URI=http://localhost:3000/oauth2callback
YOUTUBE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxx

# Pipeline Config (Optional)
PIPELINE_OUTPUT_DIR=outputs
PIPELINE_ASSETS_DIR=assets

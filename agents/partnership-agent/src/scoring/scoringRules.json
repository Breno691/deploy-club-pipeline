{
  "version": "1.0.0",
  "description": "Regras de scoring para qualificação de parceiros SmartOps IA",
  "weights": {
    "acesso_a_pmes":          { "max": 20, "description": "Acesso direto a donos/gestores de PMEs" },
    "confianca_empresarios":  { "max": 20, "description": "Nível de confiança e relacionamento com empresários" },
    "complementaridade":      { "max": 15, "description": "Complementaridade de serviços com SmartOps" },

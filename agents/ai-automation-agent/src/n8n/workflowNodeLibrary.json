  "patterns": {
    "error_handling": {
      "description": "Todo workflow DEVE ter Error Trigger + Telegram alert",
      "nodes": ["n8n-nodes-base.errorTrigger", "n8n-nodes-base.telegram"],
      "telegram_message": "⚠️ ERRO — {workflow.name}\n{$json.error.message}\n{$now}"
    },
    "logging": {
      "description": "Logar todas execuções no Supabase",
      "table": "workflow_executions",
      "fields": ["workflow_id", "status", "started_at", "finished_at", "input_summary", "error_message"]
    },
    "validation": {
      "description": "Sempre validar entrada com IF node antes de processar",
      "check": "{{ $json.required_field }} não está vazio"
    },
    "retry": {
      "description": "HTTP Request nodes: maxTries=3, waitBetweenTries=2000ms"
    }
  }

{
  "name": "sales-intelligence-agent",
  "version": "1.0.0",
  "description": "Sales Intelligence Agent — Leads, qualificação, CRM, objeções e fechamento",
  "main": "sales_agent.js",
  "scripts": {
    "start": "node sales_agent.js",
    "qualify": "node sales_agent.js --mode qualify",
    "objections": "node sales_agent.js --mode objections",
    "script": "node sales_agent.js --mode script",
    "crm": "node sales_agent.js --mode crm",

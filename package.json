{
  "name": "deploy-club-ai-pipeline",
  "version": "1.0.0",
  "description": "AI Content Marketing Pipeline for Deploy Club",
  "type": "commonjs",
  "scripts": {
    "pipeline:run": "node pipeline/orchestrator.js",
    "pipeline:run:payload": "node pipeline/orchestrator.js --payload",
    "auto": "node pipeline/run_auto.js",
    "auto:dry": "node pipeline/run_auto.js --skip-post",
    "worker": "node pipeline/worker.js",
    "research": "node scripts/research.js",
    "render:ad": "node scripts/render_ad.js",
    "upload:media": "node scripts/upload_media.js",
    "install:browsers": "npx playwright install chromium",
    "create:assets": "node scripts/create_assets.js",
    "package:skills": "node scripts/package_skills.js",
    "generate:ad": "node scripts/generate_ad.js",
    "generate:copy": "node scripts/generate_copy.js",
    "server": "node pipeline/server.js",
    "dashboard": "node pipeline/dashboard-server.js",
    "ceo": "node scripts/ceo_advisor.js --task ceo_daily --mode daily",
    "proposal": "node scripts/proposal_agent.js",
    "finance": "node scripts/financial_agent.js --task finance_semanal",
    "sales": "node scripts/sales_intelligence.js --task sales_intel",
    "competitor": "node scripts/competitor_agent.js --task competitor",
    "seo": "node scripts/seo_agent.js --task seo",
    "lean": "node scripts/lean_agent.js --task lean",
    "sigma": "node scripts/six_sigma_agent.js --task six_sigma",
    "strategy": "node scripts/strategic_planning.js --task strategy --horizon 90",
    "risk": "node scripts/risk_agent.js --task risk_monitor",
    "cos": "node scripts/chief_of_staff.js --task chief_of_staff",
    "knowledge": "node scripts/knowledge_agent.js --task knowledge",
    "case-study": "node scripts/case_study_agent.js --task case_study",
    "productize": "node scripts/productization_agent.js --task productization",
    "brand": "node scripts/personal_brand_agent.js --task personal_brand",
    "authority": "node scripts/authority_agent.js --task authority",
    "partnerships": "node scripts/partnership_agent.js --task partnerships",
    "ai-lab": "node scripts/ai_lab_agent.js --task ai_lab",
    "offer": "node scripts/offer_optimization.js --task offer_opt",
    "pricing": "node scripts/pricing_agent.js --task pricing",
    "cs": "node scripts/client_success_agent.js --task client_success",
    "exec-dash": "node scripts/exec_dashboard.js --task exec_dashboard --mode daily",
    "kaizen": "node scripts/kaizen_agent.js --task kaizen",
    "cro": "node scripts/cro_agent.js --task cro",
    "journey": "node scripts/journey_agent.js --task journey",
    "revenue": "node scripts/revenue_agent.js --task revenue",
    "kpi-guardian": "node scripts/kpi_guardian.js --task kpi_guardian",
    "content-perf": "node scripts/content_performance.js --task content_perf",
    "thought": "node scripts/thought_leadership.js --task thought_leadership",
    "experiment": "node scripts/experimentation_agent.js --task experiment",
    "lead-score": "node scripts/lead_scoring.js --task lead_score",
    "meeting": "node scripts/meeting_intelligence.js --task meeting_intel",
    "expand": "node scripts/client_expansion.js --task expand",
    "change": "node scripts/change_management.js --task change",
    "delivery": "node scripts/project_delivery.js --task delivery",
    "ai-auto": "node scripts/ai_automation_discovery.js --task ai_auto",
    "org-learn": "node scripts/organizational_learning.js --task org_learn",
    "framework": "node scripts/framework_creation.js --task framework",
    "community": "node scripts/community_agent.js --task community",
    "market-opp": "node scripts/market_opportunity.js --task market_opp",
    "sync": "node scripts/sync_supabase.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.0",
    "@supabase/supabase-js": "^2.43.1",
    "@tavily/core": "^0.3.0",
    "bullmq": "^5.7.1",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "googleapis": "^140.0.0",
    "ioredis": "^5.3.2",
    "playwright": "^1.44.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12"
  }
}

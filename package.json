    "framework": "node lib/run.js \"Framework Creation\" scripts/framework_creation.js --task framework",
    "community": "node lib/run.js \"Community Agent\" scripts/community_agent.js --task community",
    "market-opp": "node lib/run.js \"Market Opportunity\" scripts/market_opportunity.js --task market_opp",
    "website-analytics": "node lib/run.js \"Website Analytics\" scripts/website_analytics_agent.js --task website_analytics",
    "ads": "node lib/run.js \"Ads Agent\" scripts/ads_agent.js --task ads",
    "process-mining": "node lib/run.js \"Process Mining\" scripts/process_mining_agent.js --task process_mining",
    "revenue-intel": "node lib/run.js \"Digital Revenue Intelligence\" scripts/digital_revenue_agent.js --task revenue_intel",
    "campaign": "node scripts/campaign_generator.js",
    "video": "node scripts/render_video.js",
    "agent-roadmap": "node scripts/agent_roadmap.js",
    "morning": "node scripts/morning.js",
    "weekly": "node scripts/weekly.js",
    "sync": "node scripts/sync_supabase.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.0",
    "@supabase/supabase-js": "^2.43.1",
    "@tavily/core": "^0.3.0",
    "bullmq": "^5.7.1",
    "dotenv": "^16.4.5",
    "edge-tts": "^1.0.1",
    "express": "^5.2.1",
    "google-tts-api": "^2.0.2",
    "googleapis": "^140.0.0",
    "ioredis": "^5.3.2",
    "playwright": "^1.44.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12"
  }
}
